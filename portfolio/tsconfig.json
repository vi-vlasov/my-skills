{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "outDir": ".",
    "rootDir": ".",
    "allowJs": false,
    "checkJs": false,
    "declaration": false,
    "sourceMap": false,
    "removeComments": false,
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "esModuleInterop": true
  },
  "include": ["main.ts"],
  "exclude": ["vendor", "assets"]
}
